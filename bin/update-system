#!/usr/bin/env bash
set -euo pipefail

log()  { echo "[update-system] $(date '+%Y-%m-%d %H:%M:%S') $*"; }
warn() { echo "[update-system] $(date '+%Y-%m-%d %H:%M:%S') WARN: $*"; }

log "Starting weekly system update..."

# ─── Brew ───────────────────────────────────────────────────────
log "Updating Homebrew..."
brew update 2>&1 || warn "brew update failed"

log "Upgrading packages..."
brew upgrade 2>&1 || warn "brew upgrade failed"

log "Installing from Brewfile.cli..."
brew bundle --file="$HOME/.dotfiles/Brewfile.cli" --jobs=1 2>&1 || warn "brew bundle Brewfile.cli failed"

log "Installing from Brewfile.desktop..."
brew bundle --file="$HOME/.dotfiles/Brewfile.desktop" --jobs=1 2>&1 || warn "brew bundle Brewfile.desktop failed"

log "Cleaning up..."
brew cleanup 2>&1 || warn "brew cleanup failed"

# ─── Mise ───────────────────────────────────────────────────────
log "Upgrading mise tools..."
export GITHUB_TOKEN
GITHUB_TOKEN="$(gh auth token 2>/dev/null)" || warn "failed to get GITHUB_TOKEN from gh"
mise upgrade --yes 2>&1 || warn "mise upgrade failed"

# ─── macOS software updates ────────────────────────────────────
log "Installing macOS software updates..."
sudo softwareupdate -i -a 2>&1 || warn "softwareupdate failed"

log "Done."
